.DS_Store

# Local Python/build artifacts
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
build/
dist/

# Generated pipeline outputs and caches
data/
*.gdb/
sflorida_outputs/
*_outputs/
outputs/
cache/

# Large data/export formats
*.parquet
*.jsonl

# Local run logs
run_log*.txt

# External drive mounts or copied mount contents
/Volumes/
Volumes/
KINGSTON/
/Volumes/KINGSTON/

# Large generated delivery bundle (prepared locally for Google Drive)
/deliverables/google_drive_phase2/

# Driver 1003 HTML research deliverables are intentionally committed.
# Keep any accidental data/debug artifacts out of that curated tree.
/deliverables/driver_1003/**/*.csv
/deliverables/driver_1003/**/*.parquet
/deliverables/driver_1003/**/*.jsonl
/deliverables/driver_1003/**/debug/
/deliverables/driver_1003/**/legacy_selected_maps/
